{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "jetpack-theme/blur-headline",
	"version": "1.0.0",
	"title": "Blur-In Headline",
	"category": "jetpack-theme",
	"description": "Scroll-driven word-by-word blur reveal paragraph.",
	"keywords": [ "blur", "headline", "animation" ],
	"textdomain": "jetpack-theme",
	"editorScript": "file:../../build/editor.js",
	"viewScript": "file:../../build/blur-view.js",
	"attributes": {
		"text": {
			"type": "string",
			"default": "Grow your audience without the grind, speed up every page without the hassle, and secure your content without losing sleep—Jetpack handles all three so you can focus on what you love most: creating."
		}
	},
	"supports": { "html": false, "multiple": false },
	"render": "file:./render.php"
}

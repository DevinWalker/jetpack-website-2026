{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "jetpack-theme/hero",
	"version": "1.0.0",
	"title": "Hero Section",
	"category": "jetpack-theme",
	"description": "The main hero section for the Jetpack landing page.",
	"keywords": [ "hero", "jetpack", "landing" ],
	"textdomain": "jetpack-theme",
	"editorScript": "file:../../build/editor.js",
	"viewScript": [
		"file:../../build/hero-view.js",
		"file:../../build/hero-card-swap.js"
	],
	"attributes": {
		"badgeText":     { "type": "string", "default": "Now Available" },
		"changelogText": { "type": "string", "default": "Jetpack Social in 15.7" },
		"changelogUrl":  { "type": "string" },
		"headlineLine1": { "type": "string", "default": "Give WordPress" },
		"headlineAccent":{ "type": "string", "default": "Superpowers" },
		"subheadline":   { "type": "string", "default": "Your site could be losing visitors right now—to slow load times, security gaps, or content no one can find. Jetpack handles the behind-the-scenes complexity so you can focus on creating great content and growing your audience." },
		"ctaText":       { "type": "string", "default": "Get Started Free" },
		"ctaUrl":        { "type": "string" }
	},
	"supports": { "html": false, "multiple": false },
	"render": "file:./render.php"
}

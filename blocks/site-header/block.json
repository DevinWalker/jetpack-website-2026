{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "jetpack-theme/site-header",
	"version": "1.0.0",
	"title": "Site Header",
	"category": "jetpack-theme",
	"description": "Animated site header with WordPress nav menus and Interactivity API dropdown/mobile support.",
	"keywords": [ "header", "navigation", "menu" ],
	"textdomain": "jetpack-theme",
	"editorScript": "file:../../build/editor.js",
	"attributes": {
		"ctaText": { "type": "string", "default": "Try for free" },
		"ctaUrl":  { "type": "string", "default": "https://jetpack.com/pricing/" }
	},
	"supports": { "html": false, "multiple": false },
	"render": "file:./render.php"
}

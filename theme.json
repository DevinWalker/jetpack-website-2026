{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultPalette": false,
			"palette": [
				{ "slug": "accent",             "color": "#a8d946", "name": "Accent" },
				{ "slug": "background",         "color": "#f5f5f5", "name": "Background" },
				{ "slug": "foreground",         "color": "#0a0a0a", "name": "Foreground" },
				{ "slug": "frame",              "color": "#ffffff", "name": "Frame" },
				{ "slug": "muted",              "color": "#f5f5f5", "name": "Muted" },
				{ "slug": "muted-foreground",   "color": "#737373", "name": "Muted Foreground" },
				{ "slug": "border",             "color": "#e5e5e5", "name": "Border" },
				{ "slug": "card-primary",       "color": "#a8d946", "name": "Card Primary" },
				{ "slug": "card-secondary",     "color": "#e8f5c8", "name": "Card Secondary" },
				{ "slug": "card-foreground",    "color": "#171717", "name": "Card Foreground" },
				{ "slug": "white",              "color": "#ffffff", "name": "White" },
				{ "slug": "gray-0",             "color": "#f6f7f7", "name": "Gray 0" },
				{ "slug": "gray-70",            "color": "#646970", "name": "Gray 70" },
				{ "slug": "green-0",            "color": "#f0f6e8", "name": "Green 0" },
				{ "slug": "jetpack-green-50",   "color": "#069e08", "name": "Jetpack Green 50" },
				{ "slug": "jetpack-green-60",   "color": "#007117", "name": "Jetpack Green 60" },
				{ "slug": "sand",               "color": "#f0f2eb", "name": "Sand" }
			]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": {
				"minViewportWidth": "640px",
				"maxViewportWidth": "1280px"
			},
			"fontFamilies": [
				{
					"fontFamily": "Geist, system-ui, -apple-system, sans-serif",
					"slug": "sans",
					"name": "Geist Sans"
				},
				{
					"fontFamily": "Geist Mono, ui-monospace, monospace",
					"slug": "mono",
					"name": "Geist Mono"
				}
			],
			"fontSizes": [
				{
					"slug": "x-small",
					"name": "Extra Small",
					"size": "0.8125rem",
					"fluid": { "min": "0.75rem", "max": "0.8125rem" }
				},
				{
					"slug": "small",
					"name": "Small",
					"size": "0.9375rem",
					"fluid": { "min": "0.875rem", "max": "0.9375rem" }
				},
				{
					"slug": "medium",
					"name": "Medium",
					"size": "1.0625rem",
					"fluid": { "min": "1rem", "max": "1.0625rem" }
				},
				{
					"slug": "large",
					"name": "Large",
					"size": "1.25rem",
					"fluid": { "min": "1.125rem", "max": "1.25rem" }
				},
				{
					"slug": "x-large",
					"name": "Extra Large",
					"size": "1.75rem",
					"fluid": { "min": "1.375rem", "max": "1.75rem" }
				},
				{
					"slug": "xx-large",
					"name": "2X Large",
					"size": "2.25rem",
					"fluid": { "min": "1.75rem", "max": "2.25rem" }
				},
				{
					"slug": "xxx-large",
					"name": "3X Large",
					"size": "3.25rem",
					"fluid": { "min": "2.25rem", "max": "3.25rem" }
				}
			]
		},
		"spacing": {
			"units": [ "px", "em", "rem", "vh", "vw", "%" ]
		},
		"layout": {
			"contentSize": "64rem",
			"wideSize": "56rem"
		}
	},
	"styles": {
		"color": {
			"background": "#f5f5f5",
			"text": "#0a0a0a"
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--sans)",
			"fontSize": "1rem",
			"lineHeight": "1.5"
		},
		"elements": {
			"link": {
				"typography": { "textDecoration": "none" }
			}
		},
		"blocks": {
			"core/html": {
				"spacing": {
					"margin": { "top": "0", "bottom": "0" }
				}
			},
			"core/post-title": {
				"typography": {
					"fontWeight": "500",
					"letterSpacing": "-0.025em",
					"lineHeight": "1.15"
				}
			},
			"core/post-date": {
				"color": {
					"text": "#737373"
				},
				"typography": {
					"fontSize": "0.8125rem"
				}
			},
			"core/post-excerpt": {
				"color": {
					"text": "#737373"
				},
				"typography": {
					"fontSize": "1rem",
					"lineHeight": "1.7"
				}
			},
			"core/post-featured-image": {
				"border": {
					"radius": "0.75rem"
				}
			},
			"core/query-pagination": {
				"typography": {
					"fontSize": "0.875rem"
				}
			}
		}
	},
	"customTemplates": [
		{
			"name": "front-page",
			"title": "Front Page",
			"postTypes": [ "page" ]
		},
		{
			"name": "page",
			"title": "Page",
			"postTypes": [ "page" ]
		}
	],
	"templateParts": []
}
